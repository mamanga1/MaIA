def enjambre_init():
    print("\n🐝 Inicializando nodo MaIA...")
    os.makedirs(ENJAMBRE_DIR, exist_ok=True)
    torrc_line = f"HiddenServiceDir {ONION_DIR}\nHiddenServicePort {PUERTO_P2P} 127.0.0.1:{PUERTO_P2P}"
    torrc_content = subprocess.getoutput("sudo cat /etc/tor/torrc 2>/dev/null")
    if "HiddenServiceDir /var/lib/tor/maia" not in torrc_content:
        with open("/tmp/torrc_add.txt", "w") as f:
            f.write(f"\n# MaIA Enjambre\n{torrc_line}\n")
        os.system("sudo bash -c 'cat /tmp/torrc_add.txt >> /etc/tor/torrc'")
        os.system("sudo systemctl restart tor")
        os.system("rm /tmp/torrc_add.txt")
    time.sleep(5)
    result = subprocess.getoutput(f"sudo cat {ONION_DIR}/hostname 2>/dev/null")
    if result:
        print(f"\n✅ Servicio oculto activo: 🧅 {result.strip()}:{PUERTO_P2P}")
        identidad = {"onion": result.strip(), "puerto": PUERTO_P2P, "creado": datetime.now().ctime()}
        with open(os.path.join(ENJAMBRE_DIR, "identidad.json"), "w") as f:
            json.dump(identidad, f, indent=2)
