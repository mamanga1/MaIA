# ==================== RESTAURAR DNS ====================
def restaurar_dns():
    try:
        os.system("sudo chattr -i /etc/resolv.conf 2>/dev/null")
        os.system("sudo rm /etc/resolv.conf 2>/dev/null")
        with open("/tmp/resolv.conf.tmp", "w") as f:
            f.write("nameserver 1.1.1.1\nnameserver 8.8.8.8\n")
        os.system("sudo cp /tmp/resolv.conf.tmp /etc/resolv.conf")
        os.system("sudo chattr +i /etc/resolv.conf")
    except:
        pass

# ==================== REPUTACIÓN ====================
def cargar_reputacion():
    if os.path.exists(REPUTACION_FILE):
        try:
            with open(REPUTACION_FILE, "r") as f:
                return json.load(f)
        except:
            pass
    return {"nodos": {}, "config": {"confianza_inicial": 50, "voto_positivo": 10, "voto_negativo": -25, "umbral_confiable": 75, "umbral_sospechoso": 25}}

def guardar_reputacion(rep):
    os.makedirs(ENJAMBRE_DIR, exist_ok=True)
    with open(REPUTACION_FILE, "w") as f:
        json.dump(rep, f, indent=2)

def actualizar_reputacion(nodo_id, cambio, motivo):
    rep = cargar_reputacion()
    if nodo_id not in rep["nodos"]:
        rep["nodos"][nodo_id] = {"confianza": rep["config"]["confianza_inicial"], "votos_positivos": 0, "votos_negativos": 0, "historial": []}
    n = rep["nodos"][nodo_id]
    n["confianza"] = max(0, min(100, n["confianza"] + cambio))
    if cambio > 0: n["votos_positivos"] += 1
    else: n["votos_negativos"] += 1
    n["historial"].append({"timestamp": datetime.now().strftime("%H:%M:%S"), "cambio": cambio, "motivo": motivo})
    n["historial"] = n["historial"][-10]
    guardar_reputacion(rep)
    return n["confianza"]

def verificar_hallazgo_tecnico(dominio, ip):
    cmd = f"curl -s -o /dev/null -w '%{{http_code}}' --max-time 7 http://{ip} -H 'Host: {dominio}'"
    try:
        status = subprocess.check_output(cmd, shell=True).decode().strip()
        return status in ["200", "301", "302", "403", "404"]
    except:
        return False

